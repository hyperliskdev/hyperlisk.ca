---
import type { DashboardDef } from "../lib/dashboards";

interface Props {
  dashboard: DashboardDef;
}
const { dashboard } = Astro.props;
---
<section
  class="dash card"
  data-endpoint={dashboard.endpoint}
  data-refresh={dashboard.refreshSeconds}
>
  <header class="dash__head">
    <div>
      <h3 class="dash__title">{dashboard.title}</h3>
      <p class="dash__desc">{dashboard.description}</p>
    </div>
    <span class="dash__status mono" data-status="idle" aria-live="polite">
      <span class="dash__dot"></span><span class="dash__status-text">connecting…</span>
    </span>
  </header>

  <div class="dash__metrics" data-metrics hidden></div>

  <div class="dash__note mono" data-note hidden></div>

  <div class="dash__state mono" data-state>
    <span class="dash__spinner" aria-hidden="true"></span>
    requesting <code>{dashboard.endpoint}</code>…
  </div>

  <footer class="dash__foot mono" data-foot hidden>
    updated <time data-updated></time>
  </footer>
</section>

<style>
  .dash {
    background: var(--surface);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.25rem;
  }
  .dash__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .dash__title {
    margin: 0;
    font-size: 1.15rem;
  }
  .dash__desc {
    margin: 0.25rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .dash__status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .dash__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sev-info);
  }
  .dash[data-health="ok"] .dash__dot { background: var(--sev-low); }
  .dash[data-health="error"] .dash__dot { background: var(--sev-critical); }
  .dash[data-health="ok"] .dash__status { color: var(--sev-low); }
  .dash[data-health="error"] .dash__status { color: var(--sev-critical); }

  .dash__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(8.5rem, 1fr));
    gap: 0.75rem;
    margin-top: 1.1rem;
  }
  .metric {
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 0.7rem 0.8rem;
  }
  .metric__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }
  .metric__value {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 0.2rem;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .metric__unit {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
  }
  .metric__trend { font-size: 0.85rem; }
  .metric__trend--up { color: var(--sev-low); }
  .metric__trend--down { color: var(--sev-critical); }

  .dash__note,
  .dash__state,
  .dash__foot {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .dash__state code {
    font-size: 0.85em;
  }
  .dash__foot {
    border-top: var(--border-w) solid var(--border);
    padding-top: 0.7rem;
  }
  .dash__spinner {
    display: inline-block;
    width: 0.8rem;
    height: 0.8rem;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: dash-spin 0.7s linear infinite;
    vertical-align: -1px;
    margin-right: 0.35rem;
  }
  @keyframes dash-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  import { fetchJSON, ApiError } from "../lib/api";
  import type { DashboardPayload, Metric } from "../lib/dashboards";

  function trendArrow(t?: Metric["trend"]): string {
    if (t === 1) return '<span class="metric__trend metric__trend--up">▲</span>';
    if (t === -1) return '<span class="metric__trend metric__trend--down">▼</span>';
    return "";
  }

  function renderMetric(m: Metric): string {
    const unit = m.unit ? `<span class="metric__unit">${m.unit}</span>` : "";
    return `<div class="metric">
      <div class="metric__label">${escapeHtml(m.label)}</div>
      <div class="metric__value">${escapeHtml(String(m.value))}${unit}${trendArrow(m.trend)}</div>
    </div>`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
    );
  }

  function initDashboard(el: HTMLElement) {
    const endpoint = el.dataset.endpoint!;
    const refresh = Number(el.dataset.refresh ?? "0");
    const $metrics = el.querySelector<HTMLElement>("[data-metrics]")!;
    const $note = el.querySelector<HTMLElement>("[data-note]")!;
    const $state = el.querySelector<HTMLElement>("[data-state]")!;
    const $foot = el.querySelector<HTMLElement>("[data-foot]")!;
    const $updated = el.querySelector<HTMLTimeElement>("[data-updated]")!;
    const $statusText = el.querySelector<HTMLElement>(".dash__status-text")!;

    async function load() {
      try {
        const data = await fetchJSON<DashboardPayload>(endpoint);
        el.dataset.health = "ok";
        $statusText.textContent = "live";
        $metrics.innerHTML = (data.metrics ?? []).map(renderMetric).join("");
        $metrics.hidden = data.metrics?.length ? false : true;
        if (data.note) {
          $note.textContent = data.note;
          $note.hidden = false;
        } else {
          $note.hidden = true;
        }
        const when = new Date(data.updatedAt);
        $updated.dateTime = data.updatedAt;
        $updated.textContent = isNaN(when.getTime())
          ? data.updatedAt
          : when.toLocaleString();
        $foot.hidden = false;
        $state.hidden = true;
      } catch (err) {
        el.dataset.health = "error";
        const status = err instanceof ApiError ? err.status : undefined;
        $statusText.textContent = "offline";
        $state.hidden = false;
        $state.innerHTML =
          status === undefined
            ? `backend not reachable at <code>${escapeHtml(endpoint)}</code> — start your Rust API and set <code>PUBLIC_API_BASE</code>.`
            : `endpoint returned an error (${status}).`;
      }
    }

    load();
    if (refresh > 0) {
      setInterval(load, refresh * 1000);
    }
  }

  document
    .querySelectorAll<HTMLElement>(".dash[data-endpoint]")
    .forEach(initDashboard);
</script>
