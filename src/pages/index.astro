---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import CategoryBadge from "../components/CategoryBadge.astro";
import { categoryBlurb, categoryColor } from "../lib/categories";

const allPosts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recent = allPosts.slice(0, 6);

// topics = every category used across posts, ordered by post count
const counts = new Map<string, number>();
for (const p of allPosts)
  for (const c of p.data.categories) counts.set(c, (counts.get(c) ?? 0) + 1);
const topics = [...counts.keys()].sort((a, b) => counts.get(b)! - counts.get(a)!);
---
<BaseLayout title="hyperlisk" wide>
  <section class="hero">
    <p class="hero__kicker mono">// carter tomlenovich</p>
    <h1 class="hero__title">hyperlisk</h1>
    <p class="hero__lede">
      A place for me to organize my thoughts.
    </p>
    <div class="hero__links mono">
      <a class="btn" href="/posts">explore posts →</a>
      <span class="btn btn--soon" aria-disabled="true">dashboards · soon</span>
    </div>
  </section>

  {topics.length > 0 && (
    <section class="home-section">
      <h2 class="home-section__title">Topics</h2>
      <div class="topic-grid">
        {topics.map((slug) => (
          <a href={`/${slug}`} class="topic" style={`--topic-color:${categoryColor(slug)}`}>
            <CategoryBadge slug={slug} />
            {categoryBlurb(slug) && <p>{categoryBlurb(slug)}</p>}
          </a>
        ))}
      </div>
    </section>
  )}

  {recent.length > 0 && (
    <section class="home-section">
      <div class="home-section__head">
        <h2 class="home-section__title">Recent posts</h2>
      </div>
      <div class="card-grid">
        {recent.map((p) => (
          <PostCard
            href={`/posts/${p.slug}`}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            tags={p.data.tags}
            categories={p.data.categories}
            severity={p.data.severity}
          />
        ))}
      </div>
    </section>
  )}

  <section class="home-section">
    <div class="home-section__head">
      <h2 class="home-section__title">Dashboards</h2>
    </div>
    <div class="dash-soon">
      <span class="badge badge--dash">coming soon</span>
      <p>
        Live panels fed by my own self-hosted Rust collectors are in the works.
        Check back soon.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 2.5rem;
    border-bottom: var(--border-w) solid var(--border);
    margin-bottom: 2.5rem;
  }
  .hero__kicker {
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .hero__title {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 8vw, 4rem);
    margin: 0;
    letter-spacing: -0.03em;
  }
  .hero__lede {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 40rem;
    margin: 0.75rem 0 1.5rem;
  }
  .hero__links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .home-section {
    margin-bottom: 3rem;
  }
  .home-section__title {
    margin: 0;
  }
  .home-section__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }
  .home-section .home-section__title {
    margin-bottom: 1.1rem;
  }
  .home-section__head .home-section__title {
    margin-bottom: 0;
  }
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--gap);
  }
  .topic {
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 1rem 1.1rem;
    color: var(--text);
  }
  .topic:hover {
    text-decoration: none;
    border-color: var(--topic-color, var(--border-strong));
  }
  .topic p {
    margin: 0.6rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--gap);
  }
  .btn--soon {
    color: var(--text-muted);
    opacity: 0.65;
    cursor: not-allowed;
  }
  .dash-soon {
    border: var(--border-w) dashed var(--border-strong);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 1.25rem 1.4rem;
  }
  .dash-soon p {
    margin: 0.7rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 40rem;
  }

</style>
