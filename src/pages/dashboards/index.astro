---
import BaseLayout from "../../layouts/BaseLayout.astro";
// NOTE: the live dashboard pieces (src/components/LiveDashboard.astro,
// src/lib/dashboards.ts) are intentionally kept for when the Rust backends
// are ready. This page is a placeholder until then.
---
<BaseLayout
  title="dashboards"
  description="Live dashboards fed by self-hosted Rust backends — coming soon."
  wide
>
  <section class="soon">
    <span class="badge badge--dash">coming soon</span>
    <h1>Dashboards</h1>
    <p>
      I'm building a set of live panels fed by my own self-hosted Rust
      collectors — security telemetry, honeypot activity, and more. They're not
      wired up yet, but they're on the way.
    </p>
    <p class="soon__cta mono">
      In the meantime, <a href="/posts">read the posts →</a>
    </p>
  </section>
</BaseLayout>

<style>
  .soon {
    max-width: 42rem;
    margin: 2rem auto;
    text-align: center;
    border: var(--border-w) dashed var(--border-strong);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 3rem 2rem;
  }
  .soon h1 {
    margin: 1rem 0 0.6rem;
  }
  .soon p {
    color: var(--text-muted);
    margin: 0 auto 0.75rem;
  }
  .soon__cta {
    margin-top: 1.25rem;
  }
</style>
