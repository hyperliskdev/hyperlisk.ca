---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="404" description="Page not found.">
  <div class="notfound">
    <p class="mono notfound__code">404</p>
    <h1>segfault — page not found</h1>
    <p>That address doesn't map to anything. Maybe it moved, or never existed.</p>
    <div class="notfound__links mono">
      <a class="btn" href="/">← back home</a>
      <a class="btn" href="/posts">browse posts</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 4rem 0;
  }
  .notfound__code {
    font-size: 4rem;
    color: var(--accent);
    margin: 0;
  }
  .notfound h1 {
    margin-top: 0.5rem;
  }
  .notfound__links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }
</style>
