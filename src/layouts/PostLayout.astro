---
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import { formatDate, isoDate } from "../lib/format";
import CategoryBadge from "../components/CategoryBadge.astro";

interface AdjLink {
  href: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  categories: string[];
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  severity?: string;
  cves?: string[];
  iocs?: string[];
  minutes?: number;
  headings?: MarkdownHeading[];
  newer?: AdjLink;
  older?: AdjLink;
}

const {
  title,
  description,
  categories,
  pubDate,
  updatedDate,
  tags = [],
  severity,
  cves = [],
  iocs = [],
  minutes,
  headings = [],
  newer,
  older,
} = Astro.props;

// TOC from top-level section headings only
const toc = headings.filter((h) => h.depth === 2);
const showToc = toc.length >= 3;
---
<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishDate={pubDate}
  updatedDate={updatedDate}
>
  <article class="post">
    <a href="/posts" class="post__back mono">← all posts</a>

    <div class="post__meta mono">
      {categories.map((c) => <CategoryBadge slug={c} href={`/${c}`} />)}
      {severity && (
        <span class:list={["badge", `badge--sev-${severity}`]}>{severity}</span>
      )}
      <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
      {minutes && <span class="post__read">{minutes} min read</span>}
      {updatedDate && (
        <span class="post__updated">updated {formatDate(updatedDate)}</span>
      )}
    </div>

    <h1 class="post__title">{title}</h1>
    <p class="post__lede">{description}</p>

    {(cves.length > 0 || iocs.length > 0) && (
      <aside class="post__intel">
        {cves.length > 0 && (
          <div class="post__intel-row">
            <span class="mono post__intel-label">CVEs</span>
            <ul class="mono">{cves.map((c) => <li>{c}</li>)}</ul>
          </div>
        )}
        {iocs.length > 0 && (
          <div class="post__intel-row">
            <span class="mono post__intel-label">IOCs</span>
            <ul class="mono">{iocs.map((i) => <li>{i}</li>)}</ul>
          </div>
        )}
      </aside>
    )}

    {showToc && (
      <nav class="post__toc" aria-label="Table of contents">
        <p class="post__toc-title mono">Contents</p>
        <ol>
          {toc.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <hr />

    <div class="post__body">
      <slot />
    </div>

    {tags.length > 0 && (
      <ul class="post__tags mono">
        {tags.map((t) => <li>#{t}</li>)}
      </ul>
    )}

    {(newer || older) && (
      <nav class="post__nav mono" aria-label="More posts">
        {older ? (
          <a class="post__nav-link post__nav-link--prev" href={older.href}>
            <span class="post__nav-dir">← older</span>
            <span class="post__nav-title">{older.title}</span>
          </a>
        ) : <span />}
        {newer ? (
          <a class="post__nav-link post__nav-link--next" href={newer.href}>
            <span class="post__nav-dir">newer →</span>
            <span class="post__nav-title">{newer.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 44rem;
    margin-inline: auto;
  }
  .post__back {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--text-muted);
  }
  .post__back:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .post__meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .post__read::before,
  .post__updated::before {
    content: "·";
    margin-right: 0.6rem;
    color: var(--border-strong);
  }
  .post__toc {
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 0.9rem 1.2rem;
    margin-top: 1.5rem;
  }
  .post__toc-title {
    margin: 0 0 0.4rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
  }
  .post__toc ol {
    margin: 0;
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .post__toc a {
    color: var(--text);
  }
  .post__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: var(--border-w) solid var(--border);
  }
  .post__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 1rem;
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
  }
  .post__nav-link:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .post__nav-link--next {
    text-align: right;
  }
  .post__nav-dir {
    color: var(--text-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .post__nav-title {
    color: var(--text);
    font-size: 0.92rem;
  }
  @media (max-width: 34rem) {
    .post__nav {
      grid-template-columns: 1fr;
    }
    .post__nav-link--next {
      text-align: left;
    }
  }
  .post__title {
    margin: 0.7rem 0 0.5rem;
    font-size: 2.1rem;
  }
  .post__lede {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }
  .post__intel {
    border: var(--border-w) solid var(--border);
    border-left: 3px solid var(--cat-threat-intel);
    border-radius: var(--radius);
    background: var(--surface-2);
    padding: 0.9rem 1.1rem;
  }
  .post__intel-row {
    display: flex;
    gap: 0.9rem;
    align-items: baseline;
  }
  .post__intel-row + .post__intel-row {
    margin-top: 0.5rem;
  }
  .post__intel-label {
    color: var(--cat-threat-intel);
    min-width: 3rem;
  }
  .post__intel ul {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-wrap: anywhere;
  }
  .post__body :global(h2),
  .post__body :global(h3),
  .post__body :global(h4) {
    scroll-margin-top: 4.5rem;
  }
  .post__body :global(h2) {
    border-bottom: var(--border-w) solid var(--border);
    padding-bottom: 0.3rem;
  }
  .post__body :global(img) {
    border-radius: var(--radius);
    border: var(--border-w) solid var(--border);
  }
  .post__body :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.4rem 0;
  }
  .post__body :global(.mermaid) {
    background: var(--surface-2);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 2.5rem 0;
    
    /* Break out of the 44rem article column to wide 68rem layout */
    width: min(var(--wide-w), 100vw - 2.5rem);
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    
    /* Enable native resizing */
    resize: both;
    overflow: auto;
    min-height: 300px;
    height: 600px;
  }
  .post__body :global(.mermaid svg) {
    display: block;
    margin: 0 auto;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
    max-height: 100% !important;
  }
  .post__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 2.5rem 0 0;
    padding: 1rem 0 0;
    border-top: var(--border-w) solid var(--border);
    color: var(--text-muted);
  }
</style>

<script>
  async function initMermaid() {
    const elements = document.querySelectorAll(".mermaid");
    if (elements.length === 0) return;

    // Dynamically import mermaid to avoid large initial JS payload
    const { default: mermaid } = await import("mermaid");

    const getTheme = () => document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "default";

    mermaid.initialize({
      startOnLoad: false,
      theme: getTheme(),
      securityLevel: "loose",
      useMaxWidth: true, // Enables responsive scaling with the resizable container
    });

    async function render() {
      elements.forEach((el) => {
        if (!el.hasAttribute("data-original")) {
          el.setAttribute("data-original", el.textContent || "");
        } else {
          el.textContent = el.getAttribute("data-original");
          el.removeAttribute("data-processed");
          el.removeAttribute("id");
        }
      });

      try {
        await mermaid.run({
          querySelector: ".mermaid",
        });
      } catch (err) {
        console.error("Mermaid rendering failed:", err);
      }
    }

    await render();

    // Re-render when theme changes dynamically
    const observer = new MutationObserver(async (mutations) => {
      for (const mutation of mutations) {
        if (mutation.attributeName === "data-theme") {
          mermaid.initialize({
            theme: getTheme(),
          });
          await render();
        }
      }
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }

  // Initialise on load
  initMermaid();
</script>

